{
  "name": "safeguard-backend",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "db:generate": "node_modules\\.bin\\prisma.cmd generate",
    "db:push": "node_modules\\.bin\\prisma.cmd db push",
    "db:studio": "node_modules\\.bin\\prisma.cmd studio"
  },
  "dependencies": {
    "@prisma/client": "5.10.2",
    "@supabase/supabase-js": "2.39.3",
    "bcryptjs": "2.4.3",
    "compression": "1.7.4",
    "cors": "2.8.5",
    "dotenv": "16.4.1",
    "express": "4.18.2",
    "express-rate-limit": "7.1.5",
    "express-validator": "7.0.1",
    "firebase-admin": "11.11.1",
    "helmet": "7.1.0",
    "morgan": "1.10.0",
    "uuid": "9.0.1",
    "winston": "3.11.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/compression": "1.7.5",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/morgan": "1.9.9",
    "@types/node": "18.19.0",
    "@types/uuid": "9.0.7",
    "@typescript-eslint/eslint-plugin": "6.19.0",
    "@typescript-eslint/parser": "6.19.0",
    "eslint": "8.56.0",
    "jest": "29.7.0",
    "prisma": "5.10.2",
    "ts-jest": "29.1.2",
    "ts-node-dev": "2.0.0",
    "typescript": "5.3.3"
  }
}
