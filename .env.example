# Root-level env example — copy relevant sections to backend/.env and frontend/.env

# ─── Backend ────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}
FRONTEND_URL=http://localhost:5173
BETTERSTACK_SOURCE_TOKEN=your-token
LOG_LEVEL=info

# ─── Frontend ───────────────────────────────────────────────
VITE_API_URL=http://localhost:3000/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...

# ─── Mobile ─────────────────────────────────────────────────
EXPO_PUBLIC_API_URL=https://your-backend.railway.app/api

# ─── GitHub Actions Secrets (set in repo settings, not here) ─
# RAILWAY_TOKEN=
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=
